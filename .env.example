# --- 번역·요약 ---
# 운영비 절감: 무료 Google 번역 (키 불필요, AI 요약 대신 번역+클립)
USE_FREE_TRANSLATE=true
# TRANSLATE_PROVIDER=google

# AI 요약 (USE_FREE_TRANSLATE=false 일 때만)
# GEMINI_API_KEY=
# GEMINI_SUMMARY_MODEL=gemini-2.5-pro
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_API_KEY=

# 기존 summary_ko 재생성 (기본: 캐시 유지)
# REFRESH_SUMMARIES=true
# SUMMARY_RETRY=false

# X(Twitter) 수집 — 기본 끔. 켜려면 true
# ENABLE_TWITTER=false

TRANSLATE_DELAY_MS=350

# --- 매일 알림 ---
# Windows 바탕화면 알림 (기본 켜짐, node-notifier 사용)
# AhnLab 등이 powershell.exe를 차단해도 node-notifier는 보통 동작합니다.
# NOTIFY_WINDOWS=false

# Discord 웹훅 (선택, 휴대폰 알림에 유용)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# 알림 클릭 시 열 URL (배포 주소 또는 로컬)
# - 로컬만: http://localhost:3000 (dev 서버 켜져 있을 때만 동작)
# - 무료 배포 예: GitHub Pages, Cloudflare Pages, Netlify
SITE_URL=http://localhost:3000

# Windows 8시 daily 작업 후 news.json을 GitHub에 push (Pages 반영, 기본 켜짐)
# 예약 작업은 git 로그인 창이 없어서 PAT가 필요합니다.
# GitHub → Settings → Developer settings → PAT (repo 권한)
# GIT_PUSH_TOKEN=ghp_xxxxxxxx
# PUSH_NEWS=false

# Windows 예약 작업 시간 (setup-daily-task 실행 시)
# DAILY_NOTIFY_HOUR=8
# DAILY_NOTIFY_MINUTE=0
